# Must match VITE_API_PROXY_PORT in client/.env.development when using Vite’s /api proxy
PORT=5001
NODE_ENV=development

# Required in production. Dev server falls back to a weak default if unset.
JWT_SECRET=your-long-random-secret

MONGO_URI=mongodb://localhost:27017/api_monitoring_system
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=api_monitoring
PG_USER=postgres
PG_PASSWORD=postgres
RABBITMQ_URL=amqp://localhost:5672
